@model ColegioSanJose.Models.DB.Alumno
@{
    ViewData["Title"] = "Nuevo Alumno";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb" style="margin-bottom:.5rem;">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Alumnos</a></li>
                <li class="breadcrumb-item active">Nuevo</li>
            </ol>
        </nav>
        <h1><i class="bi bi-person-plus me-2"></i>Registrar Alumno</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card-custom">
                <div class="card-header"><i class="bi bi-person-vcard me-2"></i>Datos del Alumno</div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border-radius:8px;font-size:.88rem;"></div>
                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label"></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Carlos" />
                            <span asp-validation-for="Nombre" class="text-danger" style="font-size:.82rem;"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Apellido" class="form-label"></label>
                            <input asp-for="Apellido" class="form-control" placeholder="Ej: Ramírez" />
                            <span asp-validation-for="Apellido" class="text-danger" style="font-size:.82rem;"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="FechaNacimiento" class="form-label"></label>
                            <input asp-for="FechaNacimiento" class="form-control" type="date" />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Grado" class="form-label"></label>
                            <select asp-for="Grado" class="form-select">
                                <option value="">-- Seleccione un grado --</option>
                                <option>Séptimo Grado</option>
                                <option>Octavo Grado</option>
                                <option>Noveno Grado</option>
                                <option>Primer Año de Bachillerato</option>
                                <option>Segundo Año de Bachillerato</option>
                            </select>
                            <span asp-validation-for="Grado" class="text-danger" style="font-size:.82rem;"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn-navy btn"><i class="bi bi-save me-1"></i>Guardar</button>
                            <a asp-action="Index" class="btn-outline-navy btn"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>