@model IEnumerable<ColegioSanJose.Models.DB.Alumno>
@{
    ViewData["Title"] = "Alumnos";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb" style="margin-bottom:.5rem;">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item active">Alumnos</li>
            </ol>
        </nav>
        <h1><i class="bi bi-people me-2"></i>Alumnos</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <form method="get" class="d-flex" style="max-width:380px;">
            <input type="text" name="searchString" class="form-control" placeholder="Buscar alumno..."
                   value="@ViewData["CurrentFilter"]" />
            <button type="submit" class="btn btn-navy ms-2"><i class="bi bi-search"></i></button>
        </form>
        <a asp-action="Create" class="btn-navy btn">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Alumno
        </a>
    </div>

    <div class="card-custom">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-people me-2"></i>Lista de Alumnos</span>
            <span class="badge" style="background:#f0ece4;color:#0f2044;font-weight:600;">@Model.Count() registros</span>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5" style="color:#718096;">
                    <i class="bi bi-inbox" style="font-size:3rem;opacity:.3;"></i>
                    <p class="mt-3">No se encontraron alumnos.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table-custom">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Nombre Completo</th>
                                <th>Fecha de Nacimiento</th>
                                <th>Grado</th>
                                <th style="text-align:right;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model)
                            {
                                <tr>
                                    <td style="color:#a0aec0;font-size:.8rem;">@a.AlumnoId</td>
                                    <td style="font-weight:600;color:#0f2044;">@a.NombreCompleto</td>
                                    <td>@(a.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "—")</td>
                                    <td>
                                        <span style="background:#dbeafe;color:#1e40af;padding:.2em .7em;border-radius:6px;font-size:.8rem;font-weight:500;">
                                            @a.Grado
                                        </span>
                                    </td>
                                    <td style="text-align:right;">
                                        <a asp-action="Details" asp-route-id="@a.AlumnoId"
                                               class="btn-sm-icon btn" style="background:#dbeafe;color:#1e40af;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@a.AlumnoId"
                                               class="btn-sm-icon btn ms-1" style="background:#fef3c7;color:#92400e;">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@a.AlumnoId"
                                               class="btn-sm-icon btn ms-1" style="background:#fee2e2;color:#991b1b;">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>