@model ColegioSanJose.Models.DB.Materia
@{
    ViewData["Title"] = "Nueva Materia";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb" style="margin-bottom:.5rem;">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Materias</a></li>
                <li class="breadcrumb-item active">Nueva</li>
            </ol>
        </nav>
        <h1><i class="bi bi-journal-plus me-2"></i>Registrar Materia</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card-custom">
                <div class="card-header"><i class="bi bi-journal-bookmark me-2"></i>Datos de la Materia</div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border-radius:8px;font-size:.88rem;"></div>
                        <div class="mb-3">
                            <label asp-for="NombreMateria" class="form-label"></label>
                            <input asp-for="NombreMateria" class="form-control" placeholder="Ej: Matemáticas" />
                            <span asp-validation-for="NombreMateria" class="text-danger" style="font-size:.82rem;"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Docente" class="form-label"></label>
                            <input asp-for="Docente" class="form-control" placeholder="Ej: Prof. Roberto Vega" />
                            <span asp-validation-for="Docente" class="text-danger" style="font-size:.82rem;"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn-navy btn"><i class="bi bi-save me-1"></i>Guardar</button>
                            <a asp-action="Index" class="btn-outline-navy btn"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>