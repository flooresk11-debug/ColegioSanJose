<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Colegio San José</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        :root { --navy:#0f2044; --gold:#c9973a; --cream:#faf8f3; --slate:#4a5568; --light:#f0ece4; }
        body { font-family:'DM Sans',sans-serif; background:var(--cream); color:var(--slate); }
        .navbar-custom { background:var(--navy); padding:.75rem 0; box-shadow:0 2px 20px rgba(0,0,0,.25); }
        .navbar-brand-text { font-family:'Playfair Display',serif; font-size:1.3rem; color:#fff !important; }
        .navbar-brand-text span { color:var(--gold); }
        .navbar-custom .nav-link { color:rgba(255,255,255,.78) !important; font-size:.88rem; font-weight:500; padding:.5rem 1rem !important; border-radius:6px; transition:background .2s; }
        .navbar-custom .nav-link:hover, .navbar-custom .nav-link.active { color:#fff !important; background:rgba(201,151,58,.18); }
        .page-header { background:linear-gradient(135deg,var(--navy) 0%,#1a3a6b 100%); color:#fff; padding:2.5rem 0 2rem; margin-bottom:2rem; }
        .page-header h1 { font-family:'Playfair Display',serif; font-size:2rem; margin:0; }
        .page-header .breadcrumb-item, .page-header .breadcrumb-item a { color:rgba(255,255,255,.65); font-size:.83rem; }
        .page-header .breadcrumb-item.active { color:var(--gold); }
        .page-header .breadcrumb-item+.breadcrumb-item::before { color:rgba(255,255,255,.35); }
        .card-custom { border:none; border-radius:12px; box-shadow:0 2px 16px rgba(15,32,68,.08); background:#fff; overflow:hidden; }
        .card-custom .card-header { border-bottom:1px solid var(--light); background:#fff; padding:1.2rem 1.5rem; font-weight:600; font-size:.95rem; color:var(--navy); }
        .card-custom .card-body { padding:1.5rem; }
        .table-custom { width:100%; border-collapse:collapse; font-size:.9rem; }
        .table-custom thead th { background:var(--navy); color:#fff; padding:.75rem 1rem; font-weight:500; font-size:.8rem; letter-spacing:.06em; text-transform:uppercase; border:none; }
        .table-custom tbody tr { border-bottom:1px solid var(--light); transition:background .15s; }
        .table-custom tbody tr:hover { background:#f8f5ef; }
        .table-custom tbody td { padding:.75rem 1rem; vertical-align:middle; }
        .btn-navy { background:var(--navy); color:#fff; border:none; border-radius:8px; font-weight:500; padding:.5rem 1.2rem; transition:background .2s; }
        .btn-navy:hover { background:#162e5c; color:#fff; }
        .btn-gold { background:var(--gold); color:#fff; border:none; border-radius:8px; font-weight:500; padding:.5rem 1.2rem; }
        .btn-gold:hover { background:#b5832e; color:#fff; }
        .btn-outline-navy { border:1.5px solid var(--navy); color:var(--navy); border-radius:8px; font-weight:500; padding:.5rem 1.2rem; background:transparent; }
        .btn-outline-navy:hover { background:var(--navy); color:#fff; }
        .btn-sm-icon { border:none; border-radius:6px; padding:.28rem .58rem; font-size:.8rem; }
        .badge-nota { display:inline-block; padding:.3em .65em; border-radius:6px; font-size:.8rem; font-weight:600; }
        .nota-ex { background:#d1fae5; color:#065f46; }
        .nota-bu { background:#dbeafe; color:#1e40af; }
        .nota-re { background:#fef3c7; color:#92400e; }
        .nota-df { background:#fee2e2; color:#991b1b; }
        .form-label { font-weight:500; font-size:.88rem; color:var(--navy); margin-bottom:.3rem; }
        .form-control, .form-select { border:1.5px solid #ddd; border-radius:8px; font-size:.9rem; padding:.5rem .9rem; }
        .form-control:focus, .form-select:focus { border-color:var(--navy); box-shadow:0 0 0 3px rgba(15,32,68,.1); }
        .stat-card { border-radius:12px; padding:1.4rem 1.5rem; border:none; }
        .stat-card .stat-value { font-family:'Playfair Display',serif; font-size:2.2rem; font-weight:700; line-height:1; }
        .stat-card .stat-label { font-size:.78rem; font-weight:500; opacity:.75; text-transform:uppercase; letter-spacing:.06em; }
        footer { background:var(--navy); color:rgba(255,255,255,.5); text-align:center; font-size:.78rem; padding:1.2rem; margin-top:3rem; }
        footer span { color:var(--gold); }
        .alert-success-custom { background:#d1fae5; color:#065f46; border:none; border-radius:8px; border-left:4px solid #10b981; font-weight:500; font-size:.9rem; }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-custom">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <span class="navbar-brand-text">Colegio <span>San José</span></span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <i class="bi bi-list text-white fs-4"></i>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav ms-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i> Inicio</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Alumnos" asp-action="Index"><i class="bi bi-people"></i> Alumnos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Materias" asp-action="Index"><i class="bi bi-journal-bookmark"></i> Materias</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Expedientes" asp-action="Index"><i class="bi bi-folder2-open"></i> Expedientes</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Estadisticas" asp-action="Promedios"><i class="bi bi-bar-chart-line"></i> Estadísticas</a>
                </li>
            </ul>
        </div>
    </div>
</nav>
<main>
    @if (TempData["Success"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-success-custom alert-dismissible fade show">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @RenderBody()
</main>
<footer>
    &copy; @DateTime.Now.Year — <span>Colegio San José</span> · Sistema de Expedientes Académicos
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>