@{
    ViewData["Title"] = "Inicio";
    Layout = "_Layout";
}

<div style="background:linear-gradient(135deg,#0f2044 0%,#1a3a6b 60%);padding:5rem 0 4rem;color:#fff;">
    <div class="container text-center">
        <h1 style="font-family:'Playfair Display',serif;font-size:3rem;font-weight:700;margin-bottom:1rem;">
            Colegio San José
        </h1>
        <p style="color:rgba(255,255,255,.7);font-size:1.1rem;max-width:520px;margin:0 auto 2.5rem;">
            Gestión integral de expedientes académicos, alumnos y materias.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Expedientes" asp-action="Index" class="btn btn-warning fw-bold px-4 py-2">
                <i class="bi bi-folder2-open me-2"></i>Ver Expedientes
            </a>
            <a asp-controller="Estadisticas" asp-action="Promedios" class="btn btn-outline-light fw-bold px-4 py-2">
                <i class="bi bi-bar-chart-line me-2"></i>Estadísticas
            </a>
        </div>
    </div>
</div>

<div class="container" style="margin-top:-2rem;">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card-custom h-100" style="border-top:4px solid #0f2044;">
                <div class="card-body" style="padding:2rem;">
                    <div style="width:52px;height:52px;background:#dbeafe;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.2rem;">
                        <i class="bi bi-people-fill" style="font-size:1.4rem;color:#1e40af;"></i>
                    </div>
                    <h5 style="font-family:'Playfair Display',serif;font-size:1.25rem;color:#0f2044;margin-bottom:.6rem;">Alumnos</h5>
                    <p style="color:#718096;font-size:.9rem;margin-bottom:1.5rem;">Registra y administra la información de cada estudiante.</p>
                    <a asp-controller="Alumnos" asp-action="Index" class="btn-outline-navy btn" style="font-size:.88rem;">
                        <i class="bi bi-arrow-right-circle me-1"></i>Gestionar alumnos
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-custom h-100" style="border-top:4px solid #c9973a;">
                <div class="card-body" style="padding:2rem;">
                    <div style="width:52px;height:52px;background:#fef3c7;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.2rem;">
                        <i class="bi bi-journal-bookmark-fill" style="font-size:1.4rem;color:#92400e;"></i>
                    </div>
                    <h5 style="font-family:'Playfair Display',serif;font-size:1.25rem;color:#0f2044;margin-bottom:.6rem;">Materias</h5>
                    <p style="color:#718096;font-size:.9rem;margin-bottom:1.5rem;">Administra las asignaturas y los docentes responsables.</p>
                    <a asp-controller="Materias" asp-action="Index" class="btn-outline-navy btn" style="font-size:.88rem;">
                        <i class="bi bi-arrow-right-circle me-1"></i>Gestionar materias
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-custom h-100" style="border-top:4px solid #10b981;">
                <div class="card-body" style="padding:2rem;">
                    <div style="width:52px;height:52px;background:#d1fae5;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.2rem;">
                        <i class="bi bi-folder2-open" style="font-size:1.4rem;color:#065f46;"></i>
                    </div>
                    <h5 style="font-family:'Playfair Display',serif;font-size:1.25rem;color:#0f2044;margin-bottom:.6rem;">Expedientes</h5>
                    <p style="color:#718096;font-size:.9rem;margin-bottom:1.5rem;">Consulta y gestiona los expedientes con notas y observaciones.</p>
                    <a asp-controller="Expedientes" asp-action="Index" class="btn-outline-navy btn" style="font-size:.88rem;">
                        <i class="bi bi-arrow-right-circle me-1"></i>Ver expedientes
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>