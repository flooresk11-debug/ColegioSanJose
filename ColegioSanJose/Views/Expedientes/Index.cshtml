@model IEnumerable<ColegioSanJose.Models.DB.Expediente>
@{
    ViewData["Title"] = "Expedientes";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb" style="margin-bottom:.5rem;">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item active">Expedientes</li>
            </ol>
        </nav>
        <h1><i class="bi bi-folder2-open me-2"></i>Expedientes Académicos</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="card-custom mb-4">
        <div class="card-body" style="padding:1.2rem 1.5rem;">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label">Buscar</label>
                    <input type="text" name="searchString" class="form-control" placeholder="Alumno o materia..."
                           value="@ViewData["CurrentFilter"]" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Filtrar por alumno</label>
                    <select name="alumnoFiltro" asp-items="ViewBag.Alumnos" class="form-select">
                        <option value="">— Todos —</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn-navy btn w-100"><i class="bi bi-funnel me-1"></i>Filtrar</button>
                    <a asp-action="Index" class="btn-outline-navy btn w-100"><i class="bi bi-x"></i></a>
                </div>
            </form>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <span style="font-size:.88rem;color:#718096;">@Model.Count() resultado(s)</span>
        <a asp-action="Create" class="btn-navy btn">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Expediente
        </a>
    </div>

    <div class="card-custom">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5" style="color:#718096;">
                    <i class="bi bi-folder" style="font-size:3rem;opacity:.3;"></i>
                    <p class="mt-3">No se encontraron expedientes.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table-custom">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Alumno</th>
                                <th>Materia</th>
                                <th>Docente</th>
                                <th>Nota Final</th>
                                <th>Observaciones</th>
                                <th style="text-align:right;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in Model)
                            {
                                var nota = e.NotaFinal ?? 0;
                                var cls = nota >= 9 ? "nota-ex" : nota >= 7 ? "nota-bu" : nota >= 5 ? "nota-re" : "nota-df";
                                <tr>
                                    <td style="color:#a0aec0;font-size:.8rem;">@e.ExpedienteId</td>
                                    <td style="font-weight:600;color:#0f2044;">@e.Alumno?.NombreCompleto</td>
                                    <td>@e.Materia?.NombreMateria</td>
                                    <td style="color:#718096;font-size:.88rem;">@e.Materia?.Docente</td>
                                    <td>
                                        @if (e.NotaFinal.HasValue)
                                        {
                                            <span class="badge-nota @cls">@e.NotaFinal.Value.ToString("F1")</span>
                                        }
                                        else
                                        {

                                            <span style="color:#a0aec0;">Pendiente</span>
                                        }
                                    </td>
                                    <td style="font-size:.85rem;color:#718096;">@(e.Observaciones ?? "—")</td>
                                    <td style="text-align:right;">
                                        <a asp-action="Details" asp-route-id="@e.ExpedienteId"
                                               class="btn-sm-icon btn" style="background:#dbeafe;color:#1e40af;">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@e.ExpedienteId"
                                               class="btn-sm-icon btn ms-1" style="background:#fef3c7;color:#92400e;">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@e.ExpedienteId"
                                               class="btn-sm-icon btn ms-1" style="background:#fee2e2;color:#991b1b;">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>