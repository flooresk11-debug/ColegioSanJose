@model ColegioSanJose.Models.DB.Expediente
@{
    ViewData["Title"] = "Nuevo Expediente";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb" style="margin-bottom:.5rem;">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Expedientes</a></li>
                <li class="breadcrumb-item active">Nuevo</li>
            </ol>
        </nav>
        <h1><i class="bi bi-folder-plus me-2"></i>Registrar Expediente</h1>
    </div>
</div>
<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card-custom">
                <div class="card-header"><i class="bi bi-folder2-open me-2"></i>Datos del Expediente</div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border-radius:8px;font-size:.88rem;"></div>
                        <div class="mb-3">
                            <label asp-for="AlumnoId" class="form-label">Alumno</label>
                            <select asp-for="AlumnoId" asp-items="ViewBag.AlumnoId" class="form-select">
                                <option value="">-- Seleccione un alumno --</option>
                            </select>
                            <span asp-validation-for="AlumnoId" class="text-danger" style="font-size:.82rem;"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="MateriaId" class="form-label">Materia</label>
                            <select asp-for="MateriaId" asp-items="ViewBag.MateriaId" class="form-select">
                                <option value="">-- Seleccione una materia --</option>
                            </select>
                            <span asp-validation-for="MateriaId" class="text-danger" style="font-size:.82rem;"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NotaFinal" class="form-label"></label>
                            <input asp-for="NotaFinal" class="form-control" type="number" step="0.1" min="0" max="10" placeholder="0.0 – 10.0" />
                            <span asp-validation-for="NotaFinal" class="text-danger" style="font-size:.82rem;"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Observaciones" class="form-label"></label>
                            <textarea asp-for="Observaciones" class="form-control" rows="3" placeholder="Observaciones del docente..."></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn-navy btn"><i class="bi bi-save me-1"></i>Guardar</button>
                            <a asp-action="Index" class="btn-outline-navy btn"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>