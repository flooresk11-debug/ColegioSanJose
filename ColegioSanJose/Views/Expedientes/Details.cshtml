@model ColegioSanJose.Models.DB.Expediente
@{
    ViewData["Title"] = "Detalle Expediente";
    var nota = Model.NotaFinal ?? 0;
    var cls = nota >= 9 ? "nota-ex" : nota >= 7 ? "nota-bu" : nota >= 5 ? "nota-re" : "nota-df";
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb" style="margin-bottom:.5rem;">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Expedientes</a></li>
                <li class="breadcrumb-item active">Detalle</li>
            </ol>
        </nav>
        <h1><i class="bi bi-folder-check me-2"></i>Expediente #@Model.ExpedienteId</h1>
    </div>
</div>
<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card-custom">
                <div class="card-header"><i class="bi bi-folder2-open me-2"></i>Información del Expediente</div>
                <div class="card-body">
                    <dl>
                        <dt style="font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;color:#a0aec0;">Alumno</dt>
                        <dd style="font-weight:700;font-size:1.05rem;color:#0f2044;margin-bottom:1rem;">@Model.Alumno?.NombreCompleto</dd>
                        <dt style="font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;color:#a0aec0;">Grado</dt>
                        <dd style="margin-bottom:1rem;">
                            <span style="background:#dbeafe;color:#1e40af;padding:.2em .8em;border-radius:6px;font-size:.85rem;font-weight:500;">
                                @Model.Alumno?.Grado
                            </span>
                        </dd>
                        <dt style="font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;color:#a0aec0;">Materia</dt>
                        <dd style="font-weight:600;color:#0f2044;margin-bottom:1rem;">@Model.Materia?.NombreMateria</dd>
                        <dt style="font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;color:#a0aec0;">Docente</dt>
                        <dd style="color:#718096;margin-bottom:1rem;">@Model.Materia?.Docente</dd>
                        <dt style="font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;color:#a0aec0;">Nota Final</dt>
                        <dd style="margin-bottom:1rem;">
                            @if (Model.NotaFinal.HasValue)
                            {
                                <span class="badge-nota @cls" style="font-size:1.1rem;padding:.3em .9em;">
                                    @Model.NotaFinal.Value.ToString("F1")
                                </span>
                            }
                            else
                            {

                                <span style="color:#a0aec0;">Pendiente</span>
                            }
                        </dd>
                        <dt style="font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;color:#a0aec0;">Observaciones</dt>
                        <dd style="color:#718096;">@(Model.Observaciones ?? "Sin observaciones.")</dd>
                    </dl>
                    <div class="d-flex gap-2 mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.ExpedienteId" class="btn-gold btn w-100">
                            <i class="bi bi-pencil me-1"></i>Editar
                        </a>
                        <a asp-action="Index" class="btn-outline-navy btn w-100">
                            <i class="bi bi-arrow-left me-1"></i>Volver
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>